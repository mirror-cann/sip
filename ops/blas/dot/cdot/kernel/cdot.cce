extern "C" __global__ __aicore__ void cdot(__gm__ uint8_t *__restrict__ ffts_addr, __gm__ float *__restrict__ x,
                                           __gm__ float *__restrict__ y, __gm__ float *__restrict__ result,
                                           __gm__ float *__restrict__ workspace, __gm__ float *__restrict__ tiling_gm)
{
}
#endif