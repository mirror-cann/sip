extern "C" __global__ __aicore__ void ssyr2(__gm__ float *__restrict__ d_x, __gm__ float *__restrict__ d_y,
                                            __gm__ float *__restrict__ d_A, __gm__ float *__restrict__ tiling_gm)
{
}
